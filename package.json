{
  "name": "@speakai/ui",
  "version": "0.2.0",
  "description": "Speak AI design system — React + Tailwind UI components with dark/light mode, WCAG AA, and full CSS variable customization",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev:lib": "tsup --watch",
    "dev": "cd demo && npm run dev",
    "demo:build": "cd demo && npm run build",
    "demo:export": "cd demo && npm run build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "postcss": "^8.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/speakai/ui.git"
  },
  "keywords": [
    "react",
    "tailwindcss",
    "design-system",
    "ui-components",
    "dark-mode",
    "accessible",
    "speak-ai"
  ],
  "license": "MIT",
  "homepage": "https://speakai.github.io/ui"
}
