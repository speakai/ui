{
  "name": "@speakai/editor",
  "version": "0.1.0",
  "description": "Speak AI transcript editor — ProseMirror-based editing with speaker labels, find-replace, and revision management",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.mjs", "require": "./dist/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": { "react": ">=18", "react-dom": ">=18" },
  "dependencies": { "@speakai/ui": "*" },
  "devDependencies": {
    "@types/react": "^19.1.0", "@types/react-dom": "^19.1.0",
    "react": "^19.2.0", "react-dom": "^19.2.0",
    "tsup": "^8.4.0", "typescript": "^5.4.0"
  },
  "publishConfig": { "registry": "https://npm.pkg.github.com" },
  "repository": { "type": "git", "url": "https://github.com/speakai/ui.git", "directory": "packages/editor" },
  "license": "UNLICENSED"
}
